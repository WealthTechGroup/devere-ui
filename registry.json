{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "devere-ui",
  "homepage": "https://wealthtechgroup.github.io/devere-ui",
  "items": [
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A button built on the shadcn button that adds a loading state with a spinner and optional loading text.",
      "registryDependencies": ["button"],
      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "src/components/devere-ui/button.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/button.tsx"
        }
      ]
    },
    {
      "name": "loading-screen",
      "type": "registry:ui",
      "title": "Loading Screen",
      "description": "A full-area loading state with a spinning ring and optional centered logo.",
      "files": [
        {
          "path": "src/components/devere-ui/loading-screen.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/loading-screen.tsx"
        }
      ]
    },
    {
      "name": "theme-toggle",
      "type": "registry:ui",
      "title": "Theme Toggle",
      "description": "A dropdown to switch between light, dark, and system theme. Requires ThemeProvider (included).",
      "registryDependencies": ["button", "dropdown-menu"],
      "dependencies": ["lucide-react", "class-variance-authority"],
      "files": [
        {
          "path": "src/components/devere-ui/theme-provider.tsx",
          "type": "registry:component",
          "target": "@components/devere-ui/theme-provider.tsx"
        },
        {
          "path": "src/components/devere-ui/theme-toggle.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/theme-toggle.tsx"
        }
      ]
    },
    {
      "name": "tabs",
      "type": "registry:ui",
      "title": "Tabs",
      "description": "Tabs built on Base UI with default and line variants, horizontal and vertical orientation, and an animated sliding indicator.",
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "files": [
        {
          "path": "src/components/devere-ui/tabs.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/tabs.tsx"
        }
      ]
    },
    {
      "name": "dialog",
      "type": "registry:ui",
      "title": "Dialog",
      "description": "A modal dialog built on Base UI with overlay, header, scrollable body, footer, and an optional close button.",
      "registryDependencies": ["button"],
      "dependencies": ["@base-ui/react", "lucide-react"],
      "files": [
        {
          "path": "src/components/devere-ui/dialog.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/dialog.tsx"
        }
      ]
    },
    {
      "name": "not-found",
      "type": "registry:ui",
      "title": "Not Found",
      "description": "A centered 404 page with icon, title, and description. Title and description are customizable.",
      "registryDependencies": ["card"],
      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "src/components/devere-ui/not-found.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/not-found.tsx"
        }
      ]
    },
    {
      "name": "table",
      "type": "registry:ui",
      "title": "Table",
      "description": "A styled table with header, body, footer, and a truncated cell helper.",
      "files": [
        {
          "path": "src/components/devere-ui/table.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/table.tsx"
        }
      ]
    },
    {
      "name": "data-table",
      "type": "registry:ui",
      "title": "Data Table",
      "description": "A TanStack Table wrapper with sorting, filtering, pagination, column visibility, and CSV export. Built from the shadcn tasks example.",
      "registryDependencies": [
        "badge",
        "button",
        "command",
        "dropdown-menu",
        "input",
        "popover",
        "select",
        "separator"
      ],
      "dependencies": ["@tanstack/react-table", "lucide-react", "cmdk"],
      "files": [
        {
          "path": "src/components/devere-ui/table.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/table.tsx"
        },
        {
          "path": "src/components/devere-ui/data-table.tsx",
          "type": "registry:ui",
          "target": "@components/devere-ui/data-table.tsx"
        }
      ]
    }
  ]
}
